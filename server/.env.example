# ── Django ──────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ── MongoDB ──────────────────────────────────────
# Add your MongoDB Atlas connection string here when ready
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=KheloMoreDB

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXP_DELTA_SECONDS=604800

# ── AES Encryption ───────────────────────────────
# Generate with: python -c "from Crypto.Random import get_random_bytes; import base64; print(base64.b64encode(get_random_bytes(32)).decode())"
ENCRYPTION_KEY=your-32-byte-base64-encoded-key
IV=your-16-byte-base64-encoded-iv

# ── CORS ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
